<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Balance Simulator | Scottish Widows Style</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --sw-red: #e60012;
            --sw-dark-teal: #002e3b;
            --sw-light-gray: #f8fafc;
            --sw-border: #e2e8f0;
            --sw-green: #059669;
        }

        body {
            font-family: "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background-color: white;
            color: var(--sw-dark-teal);
            margin: 0;
            overflow-x: hidden;
        }

        /* Navigation Mockup */
        .nav-mock {
            height: 70px;
            border-bottom: 1px solid var(--sw-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 5%;
            background: white;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        /* Hero Section */
        .hero-section {
            padding: 80px 20px 40px;
            text-align: center;
            max-width: 850px;
            margin: 0 auto;
        }
        .hero-title {
            font-size: 44px;
            font-weight: 800;
            margin-bottom: 15px;
            letter-spacing: -0.02em;
            line-height: 1.1;
        }
        .hero-subtitle {
            font-size: 19px;
            color: #475569;
            line-height: 1.6;
        }

        /* Balance Stage */
        .balance-container {
            padding: 20px 5%;
        }
        .balance-stage {
            height: 420px;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: var(--sw-light-gray);
            border-radius: 32px;
            position: relative;
            border: 1px solid var(--sw-border);
            overflow: hidden;
        }

        /* Scale Mechanics */
        .pivot {
            position: absolute;
            bottom: 100px;
            width: 0;
            height: 0;
            border-left: 30px solid transparent;
            border-right: 30px solid transparent;
            border-bottom: 50px solid #94a3b8;
            z-index: 1;
        }
        .beam {
            width: 75%;
            max-width: 750px;
            height: 8px;
            background: #64748b;
            border-radius: 10px;
            position: relative;
            transform-origin: center;
            transition: transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
            z-index: 2;
        }
        
        /* Weights Slots */
        .slot {
            position: absolute;
            top: -140px;
            width: 280px;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            justify-items: center;
        }
        .left-slot { left: 0; }
        .right-slot { right: 0; }

        /* Icon Animation */
        .weight-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            animation: dropIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            transition: transform 0.5s;
        }
        @keyframes dropIn { 
            from { opacity: 0; transform: translateY(-40px) scale(0.6); } 
            to { opacity: 1; transform: translateY(0) scale(1); } 
        }

        .icon-box {
            width: 64px;
            height: 64px;
            border-radius: 18px;
            background: white;
            border: 1px solid var(--sw-border);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.06);
        }
        .weight-label {
            font-size: 11px;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: center;
        }

        /* Interaction Panels */
        .control-grid {
            max-width: 1050px;
            margin: 60px auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            padding: 0 20px;
        }
        .control-card {
            background: white;
            border: 1px solid var(--sw-border);
            padding: 40px;
            border-radius: 24px;
            transition: all 0.3s;
        }
        .control-card:hover {
            border-color: #cbd5e1;
            box-shadow: 0 25px 30px -10px rgba(0,0,0,0.05);
        }
        .card-title {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .button-group {
            display: flex;
            flex-wrap: wrap;
            gap: 14px;
        }
        .add-btn {
            background: white;
            border: 2px solid var(--sw-dark-teal);
            padding: 14px 28px;
            border-radius: 40px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
        }
        .add-btn:hover {
            background: var(--sw-dark-teal);
            color: white;
        }

        /* Footer Entry Button */
        .footer-action {
            text-align: center;
            padding: 40px 0 120px;
        }
        .btn-pivot {
            background-color: var(--sw-red);
            color: white;
            padding: 22px 70px;
            border-radius: 60px;
            font-size: 22px;
            font-weight: 800;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 15px;
            box-shadow: 0 12px 25px rgba(230, 0, 18, 0.25);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn-pivot:hover {
            background-color: #c0000f;
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(230, 0, 18, 0.35);
        }
        .btn-pivot svg {
            transition: transform 0.3s;
        }
        .btn-pivot:hover svg {
            transform: translateX(8px);
        }
    </style>
</head>
<body>

    <nav class="nav-mock">
        <div style="display: flex; align-items: center; gap: 10px;">
            <div style="background: var(--sw-red); width: 32px; height: 32px; border-radius: 6px;"></div>
            <span style="font-weight: 900; letter-spacing: 1.5px; font-size: 22px;">SCOTTISH WIDOWS</span>
        </div>
        <div style="display: flex; gap: 35px; font-size: 14px; font-weight: 600; color: #475569;">
            <span>Personal</span>
            <span>Employers</span>
            <span>Advisers</span>
        </div>
    </nav>

    <header class="hero-section">
        <h1 class="hero-title">Life is a weight. Let's balance it.</h1>
        <p class="hero-subtitle">Add your financial commitments and current protections to see how stable your scale is. We're here to help you find your pivot point.</p>
    </header>

    <div class="balance-container">
        <div class="balance-stage">
            <!-- Scale Visualization -->
            <div id="beam" class="beam">
                <div id="left-slot" class="slot left-slot"></div>
                <div id="right-slot" class="slot right-slot"></div>
            </div>
            <div class="pivot"></div>
        </div>
    </div>

    <main class="control-grid">
        <!-- Commitments (Negative weights) -->
        <section class="control-card">
            <div class="card-title">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                <span>Commitments</span>
            </div>
            <div class="button-group">
                <button class="add-btn" onclick="addItem('burden', 'child', 'Education')">Education</button>
                <button class="add-btn" onclick="addItem('burden', 'house', 'Mortgage')">Mortgage</button>
                <button class="add-btn" onclick="addItem('burden', 'care', 'Family Care')">Family Care</button>
            </div>
        </section>

        <!-- Protections (Positive weights) -->
        <section class="control-card">
            <div class="card-title" style="color: var(--sw-green);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                <span>Protections</span>
            </div>
            <div class="button-group">
                <button class="add-btn" onclick="addItem('guard', 'life', 'Life Cover')">Life Cover</button>
                <button class="add-btn" onclick="addItem('guard', 'health', 'Critical Illness')">Health</button>
                <button class="add-btn" onclick="addItem('guard', 'save', 'Savings')">Savings</button>
            </div>
        </section>
    </main>

    <div class="footer-action">
        <button class="btn-pivot" onclick="scrollToTop()">
            Find your pivot
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </button>
    </div>

    <script>
        let state = { guard: 0, burden: 0 };
        const iconPaths = {
            child: '<path d="M18 9v11a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V9"></path><path d="M14 6h-4V4a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v2Z"></path>',
            house: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>',
            care: '<path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z"></path><path d="M12 7v10"></path><path d="M8 11h8"></path>',
            life: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>',
            health: '<rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>',
            save: '<circle cx="12" cy="12" r="10"></circle><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"></path><path d="M12 18V6"></path>'
        };

        function addItem(type, key, label) {
            // Commitments (burden) go to the RIGHT slot, Protections (guard) go to the LEFT slot
            const slotId = type === 'guard' ? 'left-slot' : 'right-slot';
            const slot = document.getElementById(slotId);
            
            if(slot.children.length >= 9) return;

            const color = type === 'guard' ? 'var(--sw-green)' : 'var(--sw-dark-teal)';
            const item = document.createElement('div');
            item.className = 'weight-item';
            item.innerHTML = `
                <div class="icon-box" style="border-color: ${color}">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        ${iconPaths[key]}
                    </svg>
                </div>
                <div class="weight-label">${label}</div>
            `;
            
            slot.appendChild(item);
            state[type]++;
            updatePhysics();
        }

        function updatePhysics() {
            const beam = document.getElementById('beam');
            // Physics: Burden (Right) makes it tilt right (positive angle), 
            // Guard (Left) makes it tilt left (negative angle)
            const diff = state.burden - state.guard;
            const angle = Math.max(-15, Math.min(15, diff * 5));
            beam.style.transform = `rotate(${angle}deg)`;

            // Counter-rotate items so they stay upright
            document.querySelectorAll('.weight-item').forEach(el => {
                el.style.transform = `rotate(${-angle}deg)`;
            });
        }

        function scrollToTop() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
</body>
</html>
